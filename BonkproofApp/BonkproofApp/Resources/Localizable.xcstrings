    "tourSlide2Body" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Zeitplan-Tab teilt deine Fahrt in 20-Minuten-Slots — du weißt immer, wann du essen sollst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Schedule tab breaks your ride into 20-minute slots — so you always know what to reach for."
