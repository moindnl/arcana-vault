    "tourSlide0Body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter duration and average power — bonkproof instantly calculates your carb and fluid targets."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gib Dauer und Durchschnittsleistung ein — bonkproof berechnet sofort deine Kohlenhydrat- und Flüssigkeitsziele."
          }
        }
      }
    },
    "tourSlide1Body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Intensity factor determines your zone. Each zone has a precise carb range, scaled to your FTP."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Intensitätsfaktor bestimmt deine Zone. Jede Zone hat einen präzisen KH-Bereich, skaliert auf deinen FTP."
          }
        }
      }
    },
    "tourSlide2Body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Schedule tab breaks your ride into 20-minute slots — so you always know what to reach for."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Zeitplan-Tab teilt deine Fahrt in 20-Minuten-Slots — du weißt immer, wann du essen sollst."
          }
        }
      }
    },
    "tourSlide3Body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add your gels or bars in Settings. bonkproof calculates with your exact carb values — not generic estimates."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge deine Gels oder Riegel in den Einstellungen hinzu. bonkproof rechnet mit deinen exakten KH-Werten."
          }
        }
      }
    },
