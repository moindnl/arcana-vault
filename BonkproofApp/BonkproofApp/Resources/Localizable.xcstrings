    "preRideMealExplain" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3–4 g Carbs pro kg Körpergewicht, ca. 3h vor dem Start. Füllt die Glykogenspeicher vor der Belastung. Leicht verdaulich, wenig Fett und Ballaststoffe."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3–4 g carbs per kg body weight, ~3h before start. Tops up glycogen stores before effort. Choose easily digestible foods, low in fat and fibre."
