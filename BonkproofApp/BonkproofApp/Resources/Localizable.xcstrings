    "onboardingDisclaimerBody": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "bonkproof calculates estimated carbohydrate and fluid targets for endurance athletes based on sports science guidelines (Jeukendrup, Sports Medicine 2014; Sawka et al., ACSM 2007; Thomas et al., AND 2016).\n\nThese values are not medical advice and do not replace consultation with a doctor, dietitian, or sports scientist. Use at your own risk.\n\nIf you have any health conditions — such as diabetes — consult a physician before use."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "bonkproof berechnet geschätzte Kohlenhydrat- und Flüssigkeitsziele für Ausdauersportler auf Basis sportwissenschaftlicher Leitlinien (Jeukendrup, Sports Medicine 2014; Sawka et al., ACSM 2007; Thomas et al., AND 2016).\n\nDiese Werte sind keine medizinische Beratung und ersetzen nicht die Konsultation eines Arztes, Ernährungsberaters oder Sportwissenschaftlers. Nutzung auf eigene Verantwortung.\n\nBei gesundheitlichen Einschränkungen — z. B. Diabetes — bitte vorher einen Arzt konsultieren."
          }
        }
      }
    },
    "onboardingDisclaimerSources": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scientific sources: About → Formula"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wissenschaftliche Quellen: Über → Formel"
          }
        }
      }
    },
